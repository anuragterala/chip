# Copy to .env and fill in. Never commit the real .env.
DISCORD_WEBHOOK=https://discord.com/api/webhooks/XXXX/YYYY
TWITTERAPI_KEY=your_twitterapi_io_key

# Optional tuning
POLL_INTERVAL=6          # free tier floor is 1 req/5s; 6 is safe. Lower only on a paid plan.
OVERLAP_SECONDS=20
HEARTBEAT_HOURS=6
CODE_LOG_FILE=codes_log.jsonl
# MIN_CALL_SPACING=5.5   # rate-limit guard; lower if you upgrade past the free tier
